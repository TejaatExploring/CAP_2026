# .gitignore

# Exclude datasets folder (large files)
Datasets/
Dataset/*.csv

# Byte-compiled / cache
__pycache__/
*.py[cod]

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Output and results (optional, comment out if you want to keep these tracked)
# outputs/
# results/
outputs/*.csv
outputs/*.npy

# Synthetic load generated artifacts
synthetic_load/*.pkl
synthetic_load/*.npy
synthetic_load/metadata.json
synthetic_load/*.png
synthetic_load/__pycache__/

# OS files
.DS_Store
Thumbs.db

# VS Code settings
.vscode/
